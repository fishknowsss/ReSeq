<Window x:Class="ReSeq.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ReSeq"
        Width="1240"
        Height="780"
        MinWidth="1024"
        MinHeight="640"
        Background="#F6F7F9"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="68" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#20242A" />
            <Setter Property="BorderBrush" Value="#CCD3DD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F1F5FA" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E6EDF6" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="#FFFFFF"
                BorderBrush="#D8DEE8"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="ChooseFolderButton"
                        Grid.Column="0"
                        Content="选择"
                        Style="{StaticResource ToolbarButton}"
                        Click="ChooseFolderButton_Click" />
                <Button x:Name="RefreshButton"
                        Grid.Column="1"
                        Content="刷新"
                        Style="{StaticResource ToolbarButton}"
                        Click="RefreshButton_Click" />
                <Button x:Name="ExecuteButton"
                        Grid.Column="2"
                        Content="执行"
                        Style="{StaticResource ToolbarButton}"
                        Click="ExecuteButton_Click"
                        IsEnabled="False" />
                <Button x:Name="UndoButton"
                        Grid.Column="3"
                        Content="撤销"
                        Style="{StaticResource ToolbarButton}"
                        Click="UndoButton_Click" />

                <StackPanel Grid.Column="4"
                            Orientation="Vertical"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="FolderPathText"
                               Text="未选择文件夹"
                               Foreground="#20242A"
                               FontSize="14"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="DropHintText"
                               Text="拖入一个视频到网格中"
                               Foreground="#435264"
                               FontSize="13"
                               Margin="0,3,0,0"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#F6F7F9">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <Grid x:Name="WorkspaceGrid"
                          Margin="18"
                          AllowDrop="True"
                          DragOver="WorkspaceGrid_DragOver"
                          Drop="WorkspaceGrid_Drop" />
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1"
                    Background="#FFFFFF"
                    BorderBrush="#D8DEE8"
                    BorderThickness="1,0,0,0"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="210" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="预览"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#20242A"
                               Margin="0,0,0,10" />
                    <ListBox x:Name="PreviewList"
                             Grid.Row="1"
                             BorderBrush="#D8DEE8"
                             BorderThickness="1"
                             Background="#FFFFFF"
                             FontSize="14"
                             Padding="8"
                             HorizontalContentAlignment="Stretch" />

                    <TextBlock Grid.Row="2"
                               Text="日志"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#20242A"
                               Margin="0,18,0,10" />
                    <ListBox x:Name="LogList"
                             Grid.Row="3"
                             BorderBrush="#D8DEE8"
                             BorderThickness="1"
                             Background="#FFFFFF"
                             FontSize="14"
                             Padding="8"
                             HorizontalContentAlignment="Stretch" />
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
