<Window x:Class="ReSeq.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ReSeq"
        Icon="Assets/ReSeq.ico"
        Width="1360"
        Height="860"
        MinWidth="1120"
        MinHeight="700"
        Background="#F3F6FA"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#17202B" />
        <SolidColorBrush x:Key="MutedBrush" Color="#536173" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#7A8797" />
        <SolidColorBrush x:Key="LineBrush" Color="#D8E0EA" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="CanvasBrush" Color="#F3F6FA" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2F6FED" />

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F7FAFD" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#9FB0C5" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.48" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryToolbarButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="#8FA8F4" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#8FA8F4" />
        </Style>

        <Style x:Key="IconText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="MetricChip" TargetType="Border">
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="#F6F8FB" />
            <Setter Property="BorderBrush" Value="#E1E7F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <Style x:Key="PanelList" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,6" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Root"
                                            Background="#F8FAFC"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10,8">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Root" Property="Background" Value="#F2F6FB" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Root" Property="Background" Value="#EAF1FF" />
                                            <Setter TargetName="Root" Property="BorderBrush" Value="#B7C8F8" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="88" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="22,12,28,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="172" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Width="46"
                            Height="46"
                            Background="#141D29"
                            CornerRadius="12"
                            Margin="0,0,12,0">
                        <TextBlock Text="X-Y"
                                   Foreground="#FFFFFF"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ReSeq"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource InkBrush}" />
                        <TextBlock Text="短剧分镜版本管理"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="1,1,0,0" />
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Column="1"
                      Margin="12,0,22,0"
                      VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#F5F8FC"
                            BorderBrush="#D9E2ED"
                            BorderThickness="1"
                            CornerRadius="9"
                            Padding="12,0">
                        <TextBlock x:Name="FolderPathText"
                                   Text="未选择文件夹"
                                   Foreground="{StaticResource InkBrush}"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Bottom"
                                Margin="0,8,0,0">
                        <Border Style="{StaticResource MetricChip}">
                            <TextBlock x:Name="VideoCountText"
                                       Text="视频 0"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                        </Border>
                        <Border Style="{StaticResource MetricChip}">
                            <TextBlock x:Name="ShotCountText"
                                       Text="镜头 0"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                        </Border>
                        <Border Style="{StaticResource MetricChip}">
                            <TextBlock x:Name="VersionCountText"
                                       Text="版本 0"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                        </Border>
                        <Border Style="{StaticResource MetricChip}">
                            <TextBlock x:Name="IssueCountText"
                                       Text="问题 0"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="ChooseFolderButton"
                            Style="{StaticResource ToolbarButton}"
                            Click="ChooseFolderButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;" Style="{StaticResource IconText}" />
                            <TextBlock Text="选择" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="RefreshButton"
                            Style="{StaticResource ToolbarButton}"
                            Click="RefreshButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" Style="{StaticResource IconText}" />
                            <TextBlock Text="刷新" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ExecuteButton"
                            Style="{StaticResource PrimaryToolbarButton}"
                            Click="ExecuteButton_Click"
                            IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" Style="{StaticResource IconText}" />
                            <TextBlock Text="执行" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="UndoButton"
                            Style="{StaticResource ToolbarButton}"
                            Margin="0"
                            Click="UndoButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7A7;" Style="{StaticResource IconText}" />
                            <TextBlock Text="撤销" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="384" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource CanvasBrush}">
                <Grid>
                    <Border x:Name="DropHintBar"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="22,18,0,0"
                            Background="#FFFFFF"
                            BorderBrush="#DDE5EF"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="13,7"
                            Panel.ZIndex="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8E5;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="13"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="0,0,8,0" />
                            <TextBlock x:Name="DropHintText"
                                       Text="选择文件夹后，将视频拖到网格位置"
                                       FontSize="13"
                                       Foreground="{StaticResource InkBrush}" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="22,64,22,22">
                        <Grid x:Name="WorkspaceGrid"
                              AllowDrop="True"
                              DragOver="WorkspaceGrid_DragOver"
                              Drop="WorkspaceGrid_Drop" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="#FFFFFF"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1,0,0,0">
                <Grid Margin="18,18,20,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="245" />
                        <RowDefinition Height="22" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="待执行"
                                   Style="{StaticResource SectionTitle}" />
                        <TextBlock x:Name="PlanStatusText"
                                   Grid.Column="1"
                                   Text="无计划"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Border Grid.Row="1"
                            Background="#FFFFFF"
                            BorderBrush="#E1E7F0"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <Grid>
                            <ListBox x:Name="PreviewList"
                                     Style="{StaticResource PanelList}" />
                            <TextBlock x:Name="PreviewEmptyText"
                                       Text="拖入视频后在这里确认改名"
                                       Foreground="{StaticResource SubtleBrush}"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="3" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="运行日志"
                                   Style="{StaticResource SectionTitle}" />
                        <TextBlock x:Name="LogStatusText"
                                   Grid.Column="1"
                                   Text="就绪"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Border Grid.Row="4"
                            Background="#FFFFFF"
                            BorderBrush="#E1E7F0"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <Grid>
                            <ListBox x:Name="LogList"
                                     Style="{StaticResource PanelList}" />
                            <TextBlock x:Name="LogEmptyText"
                                       Text="选择文件夹后显示扫描结果"
                                       Foreground="{StaticResource SubtleBrush}"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Text="就绪"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="{StaticResource MutedBrush}" />
                <TextBlock Grid.Column="1"
                           Text="安全重命名：两阶段临时文件"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="{StaticResource MutedBrush}" />
            </Grid>
        </Border>
    </Grid>
</Window>
