<Window x:Class="ReSeq.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ReSeq.Controls"
        xmlns:vm="clr-namespace:ReSeq.ViewModels"
        Title="ReSeq"
        Width="1440"
        Height="900"
        MinWidth="1220"
        MinHeight="740"
        Background="{StaticResource AppBackgroundBrush}"
        Icon="Assets/ReSeq.ico"
        FontFamily="{StaticResource AppFontFamily}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragOver="Window_DragOver"
        DragLeave="Window_DragLeave"
        Drop="Window_Drop">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="72" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="198" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="386" />
        </Grid.ColumnDefinitions>

        <Border Grid.RowSpan="3"
                Grid.Column="0"
                Background="{StaticResource RailBrush}"
                BorderBrush="{StaticResource RailBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="44"
                            Height="44"
                            CornerRadius="13"
                            Background="{StaticResource RailElevatedBrush}"
                            BorderBrush="{StaticResource RailBorderBrush}"
                            BorderThickness="1">
                        <Image Source="Assets/ReSeq.ico"
                               Width="30"
                               Height="30"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="11,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="ReSeq"
                                   Style="{StaticResource RailTitleText}" />
                        <TextBlock Text="分镜版本管理"
                                   Style="{StaticResource RailMutedText}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Row="1"
                        Style="{StaticResource RailSection}"
                        Margin="0,24,0,0">
                    <StackPanel>
                        <TextBlock Text="当前状态"
                                   Style="{StaticResource RailMutedText}" />
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{StaticResource RailTextBrush}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,0" />
                        <TextBlock Text="{Binding FolderDisplayText}"
                                   Style="{StaticResource RailMutedText}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Style="{StaticResource RailSection}"
                        Margin="0,12,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="视频"
                                   Style="{StaticResource RailMutedText}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding VideoCount}"
                                   Foreground="{StaticResource RailTextBrush}"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontWeight="SemiBold" />

                        <TextBlock Grid.Row="1"
                                   Text="镜头"
                                   Style="{StaticResource RailMutedText}"
                                   Margin="0,10,0,0" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding ShotCount}"
                                   Foreground="{StaticResource RailTextBrush}"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,0" />

                        <TextBlock Grid.Row="2"
                                   Text="版本"
                                   Style="{StaticResource RailMutedText}"
                                   Margin="0,10,0,0" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Text="{Binding VersionCount}"
                                   Foreground="{StaticResource RailTextBrush}"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,0" />

                        <TextBlock Grid.Row="3"
                                   Text="问题"
                                   Style="{StaticResource RailMutedText}"
                                   Margin="0,10,0,0" />
                        <TextBlock Grid.Row="3"
                                   Grid.Column="1"
                                   Text="{Binding IssueCount}"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource RailTextBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasIssues}" Value="True">
                                            <Setter Property="Foreground" Value="#FFD166" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="4">
                    <Button Style="{StaticResource RailButton}"
                            Click="ChooseFolderButton_Click">
                        <DockPanel>
                            <TextBlock Text="&#xE8B7;"
                                       FontFamily="Segoe Fluent Icons"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="选择文件夹" />
                        </DockPanel>
                    </Button>
                    <Button Style="{StaticResource RailButton}"
                            Click="RefreshButton_Click"
                            IsEnabled="{Binding CanRefresh}"
                            Margin="0,8,0,0">
                        <DockPanel>
                            <TextBlock Text="&#xE72C;"
                                       FontFamily="Segoe Fluent Icons"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="刷新" />
                        </DockPanel>
                    </Button>

                    <Border Margin="0,18,0,0"
                            Padding="10"
                            CornerRadius="9"
                            Background="#0F1722"
                            BorderBrush="{StaticResource RailBorderBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="安全策略"
                                       Foreground="{StaticResource RailTextBrush}"
                                       FontWeight="SemiBold"
                                       FontSize="12" />
                            <TextBlock Text="两阶段临时文件"
                                       Style="{StaticResource RailMutedText}"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Style="{StaticResource CommandSurface}">
            <Grid Margin="22,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center">
                    <TextBlock Text="分镜矩阵"
                               Style="{StaticResource SectionTitleText}" />
                    <TextBlock Text="按 X-Y 编号管理视频版本"
                               Style="{StaticResource CaptionText}"
                               Margin="0,3,0,0" />
                </StackPanel>

                <Border Grid.Column="1"
                        Style="{StaticResource FieldCard}"
                        Height="38"
                        Margin="24,0"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="&#xE8B7;"
                                   FontFamily="Segoe Fluent Icons"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,9,0" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding FolderDisplayText}"
                                   Style="{StaticResource BodyText}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Border>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButton}"
                            Click="ChooseFolderButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;"
                                       FontFamily="Segoe Fluent Icons"
                                       Margin="0,0,7,0" />
                            <TextBlock Text="选择" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}"
                            Margin="8,0,0,0"
                            Click="RefreshButton_Click"
                            IsEnabled="{Binding CanRefresh}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;"
                                       FontFamily="Segoe Fluent Icons"
                                       Margin="0,0,7,0" />
                            <TextBlock Text="刷新" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PrimaryButton}"
                            Margin="8,0,0,0"
                            Click="ExecuteButton_Click"
                            IsEnabled="{Binding CanExecutePlan}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;"
                                       FontFamily="Segoe Fluent Icons"
                                       Margin="0,0,7,0" />
                            <TextBlock Text="执行" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}"
                            Margin="8,0,0,0"
                            Click="ClearPreviewButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE894;"
                                       FontFamily="Segoe Fluent Icons"
                                       Margin="0,0,7,0" />
                            <TextBlock Text="清空" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Grid.Column="1"
              Background="{StaticResource WorkspaceBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource DropHintBanner}"
                    Margin="22,18,22,0">
                <DockPanel>
                    <TextBlock Text="&#xE8AB;"
                               FontFamily="Segoe Fluent Icons"
                               Foreground="#93C5FD"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBlock Text="{Binding DropHint}"
                               Foreground="#E5EEFF"
                               FontSize="13"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="22,12,22,0"
                    Background="{StaticResource WarningSoftBrush}"
                    BorderBrush="{StaticResource WarningBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,9"
                    Visibility="{Binding HasIssueSummary, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE7BA;"
                               FontFamily="Segoe Fluent Icons"
                               Foreground="{StaticResource WarningBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBlock Text="{Binding IssueSummary}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Margin="22,16,22,22"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="12"
                    ClipToBounds="True">
                <Grid>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  CanContentScroll="False"
                                  PanningMode="Both">
                        <StackPanel HorizontalAlignment="Left">
                            <Grid Height="34"
                                  HorizontalAlignment="Left"
                                  Visibility="{Binding Workspace.HasVideos, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="84" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource MatrixHeaderCell}">
                                    <TextBlock Text="镜头"
                                               Style="{StaticResource MatrixHeaderText}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center" />
                                </Border>
                                <ItemsControl Grid.Column="1"
                                              HorizontalAlignment="Left"
                                              ItemsSource="{Binding Workspace.VersionHeaders}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="178"
                                                    Style="{StaticResource MatrixHeaderCell}">
                                                <TextBlock Text="{Binding StringFormat=版本 {0}}"
                                                           Style="{StaticResource MatrixHeaderText}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Workspace.Rows}"
                                          HorizontalAlignment="Left"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel IsVirtualizing="True"
                                                               VirtualizationMode="Recycling" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:GridRowViewModel}">
                                        <StackPanel>
                                            <controls:DropZoneControl Target="{Binding InsertBeforeTarget}"
                                                                      Height="10"
                                                                      LineHeight="2"
                                                                      LineWidth="1400"
                                                                      Margin="84,0,0,0" />
                                            <Grid HorizontalAlignment="Left">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="84" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Width="84"
                                                        Height="144"
                                                        Style="{StaticResource RowHeaderCard}">
                                                    <StackPanel HorizontalAlignment="Center"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="镜头"
                                                                   Style="{StaticResource CaptionText}"
                                                                   HorizontalAlignment="Center" />
                                                        <TextBlock Text="{Binding X}"
                                                                   Style="{StaticResource MatrixIndexText}"
                                                                   HorizontalAlignment="Center"
                                                                   Margin="0,3,0,0" />
                                                    </StackPanel>
                                                </Border>

                                                <ItemsControl Grid.Column="1"
                                                              ItemsSource="{Binding Cells}"
                                                              HorizontalAlignment="Left"
                                                              VirtualizingPanel.IsVirtualizing="True"
                                                              VirtualizingPanel.VirtualizationMode="Recycling">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:GridCellViewModel}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <controls:DropZoneControl Target="{Binding VersionTarget}"
                                                                                          Width="10"
                                                                                          Height="144"
                                                                                          LineHeight="118"
                                                                                          LineWidth="2" />
                                                                <Grid Width="168"
                                                                      Height="144"
                                                                      Tag="{Binding CellTarget}"
                                                                      AllowDrop="True">
                                                                    <controls:VideoTileControl DataContext="{Binding Video}"
                                                                                               Tag="{Binding CellTarget}"
                                                                                               HorizontalAlignment="Center"
                                                                                               VerticalAlignment="Center">
                                                                        <controls:VideoTileControl.Style>
                                                                            <Style TargetType="{x:Type controls:VideoTileControl}">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasVideo}" Value="False">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </controls:VideoTileControl.Style>
                                                                    </controls:VideoTileControl>

                                                                    <Border Tag="{Binding CellTarget}">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border"
                                                                                   BasedOn="{StaticResource EmptyCellCard}">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasVideo}" Value="False">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <StackPanel HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center">
                                                                            <TextBlock Text="&#xE710;"
                                                                                       FontFamily="Segoe Fluent Icons"
                                                                                       Foreground="{StaticResource TextTertiaryBrush}"
                                                                                       FontSize="17"
                                                                                       HorizontalAlignment="Center" />
                                                                            <TextBlock Style="{StaticResource CaptionText}"
                                                                                       HorizontalAlignment="Center"
                                                                                       Margin="0,7,0,0">
                                                                                <TextBlock.Text>
                                                                                    <MultiBinding StringFormat="{}{0}-{1}">
                                                                                        <Binding Path="X" />
                                                                                        <Binding Path="Y" />
                                                                                    </MultiBinding>
                                                                                </TextBlock.Text>
                                                                            </TextBlock>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </Grid>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <controls:EmptyStateControl Title="{Binding Workspace.EmptyTitle}"
                                                ActionText="{Binding Workspace.EmptyActionText}"
                                                Target="{Binding Workspace.FirstVideoTarget}"
                                                ChooseRequested="EmptyState_ChooseRequested"
                                                Visibility="{Binding Workspace.ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Grid.Column="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1,0,0,0">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="3*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource InspectorSection}">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="当前概览"
                                       Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="{Binding StatusText}"
                                       DockPanel.Dock="Right"
                                       Style="{StaticResource CaptionText}"
                                       HorizontalAlignment="Right" />
                        </DockPanel>

                        <UniformGrid Columns="4"
                                     Margin="0,14,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding VideoCount}"
                                           Style="{StaticResource MetricText}" />
                                <TextBlock Text="视频"
                                           Style="{StaticResource CaptionText}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding ShotCount}"
                                           Style="{StaticResource MetricText}" />
                                <TextBlock Text="镜头"
                                           Style="{StaticResource CaptionText}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding VersionCount}"
                                           Style="{StaticResource MetricText}" />
                                <TextBlock Text="版本"
                                           Style="{StaticResource CaptionText}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding IssueCount}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock"
                                               BasedOn="{StaticResource MetricText}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasIssues}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="问题"
                                           Style="{StaticResource CaptionText}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource InspectorSection}"
                        Margin="0,14,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel>
                            <TextBlock Text="待执行"
                                       Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="{Binding PendingPlan.StatusText}"
                                       DockPanel.Dock="Right"
                                       Style="{StaticResource CaptionText}" />
                        </DockPanel>

                        <Grid Grid.Row="1"
                              Margin="0,12,0,0">
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border"
                                           BasedOn="{StaticResource EmptyPanelCard}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PendingPlan.HasContent}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8FD;"
                                               FontFamily="Segoe Fluent Icons"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               FontSize="20"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="拖入视频后显示预览"
                                               Style="{StaticResource CaptionText}"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>

                            <StackPanel Visibility="{Binding PendingPlan.HasContent, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Border Background="{StaticResource ErrorSoftBrush}"
                                        BorderBrush="{StaticResource ErrorBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,10"
                                        Visibility="{Binding PendingPlan.HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="{Binding PendingPlan.ErrorText}"
                                               Foreground="{StaticResource ErrorBrush}"
                                               TextWrapping="Wrap" />
                                </Border>
                                <controls:RenamePreviewControl ItemsSource="{Binding PendingPlan.Operations}"
                                                               Visibility="{Binding PendingPlan.HasOperations, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Style="{StaticResource InspectorSection}"
                        Margin="0,14,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel>
                            <TextBlock Text="运行日志"
                                       Style="{StaticResource SectionTitleText}" />
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource TextButton}"
                                    Click="ClearLogsButton_Click"
                                    Content="清空" />
                        </DockPanel>
                        <controls:LogListControl Grid.Row="1"
                                                 Margin="0,12,0,0"
                                                 ItemsSource="{Binding Logs}" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,1,0,0"
                Padding="18,0">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Ellipse Width="7"
                             Height="7"
                             Fill="{StaticResource AccentBrush}"
                             Margin="0,0,8,0" />
                    <TextBlock Text="{Binding StatusText}"
                               Style="{StaticResource StatusText}" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding ProgressText}"
                               Style="{StaticResource StatusText}"
                               Margin="0,0,18,0" />
                    <TextBlock Text="安全重命名：两阶段临时文件"
                               Style="{StaticResource StatusText}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
