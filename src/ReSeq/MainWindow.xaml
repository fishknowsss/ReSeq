<Window x:Class="ReSeq.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ReSeq"
        Icon="Assets/ReSeq.ico"
        Width="1360"
        Height="860"
        MinWidth="1120"
        MinHeight="700"
        Background="#EEF2F6"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#17202B" />
        <SolidColorBrush x:Key="MutedBrush" Color="#596779" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#7B8797" />
        <SolidColorBrush x:Key="LineBrush" Color="#D7DEE8" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="CanvasBrush" Color="#F5F7FA" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#E7F0FF" />

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F7FAFD" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#9FB0C5" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryToolbarButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#2563EB" />
        </Style>

        <Style x:Key="IconText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <Style x:Key="ListBoxBase" TargetType="ListBox">
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="8,6" />
                        <Setter Property="Margin" Value="0,0,0,4" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Root"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="0,0,0,1"
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Root" Property="Background" Value="#F8FAFC" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Root" Property="Background" Value="#E7F0FF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="88" />
            <RowDefinition Height="*" />
            <RowDefinition Height="34" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,24,0">
                    <Border Width="46"
                            Height="46"
                            Background="#17202B"
                            CornerRadius="12"
                            Margin="0,0,12,0">
                        <Image Source="Assets/ReSeq.ico"
                               Width="32"
                               Height="32"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ReSeq"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource InkBrush}" />
                        <TextBlock Text="短剧分镜版本管理"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}" />
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            Background="#F4F7FA"
                            BorderBrush="#DDE5EF"
                            BorderThickness="1"
                            CornerRadius="9"
                            Padding="12,8">
                        <TextBlock x:Name="FolderPathText"
                                   Text="未选择文件夹"
                                   Foreground="{StaticResource InkBrush}"
                                   FontSize="14"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>
                    <UniformGrid Grid.Row="1"
                                 Columns="4"
                                 Margin="0,8,0,0">
                        <TextBlock x:Name="VideoCountText"
                                   Text="视频 0"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13" />
                        <TextBlock x:Name="ShotCountText"
                                   Text="镜头 0"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13" />
                        <TextBlock x:Name="VersionCountText"
                                   Text="版本 0"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13" />
                        <TextBlock x:Name="IssueCountText"
                                   Text="问题 0"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13" />
                    </UniformGrid>
                </Grid>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="22,0,0,0">
                    <Button x:Name="ChooseFolderButton"
                            Style="{StaticResource ToolbarButton}"
                            Click="ChooseFolderButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;" Style="{StaticResource IconText}" />
                            <TextBlock Text="选择" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="RefreshButton"
                            Style="{StaticResource ToolbarButton}"
                            Click="RefreshButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" Style="{StaticResource IconText}" />
                            <TextBlock Text="刷新" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ExecuteButton"
                            Style="{StaticResource PrimaryToolbarButton}"
                            Click="ExecuteButton_Click"
                            IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" Style="{StaticResource IconText}" />
                            <TextBlock Text="执行" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="UndoButton"
                            Style="{StaticResource ToolbarButton}"
                            Click="UndoButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7A7;" Style="{StaticResource IconText}" />
                            <TextBlock Text="撤销" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="384" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource CanvasBrush}">
                <Grid>
                    <Border x:Name="DropHintBar"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="22,18,0,0"
                            Background="#FFFFFF"
                            BorderBrush="#D7DEE8"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="12,7"
                            Panel.ZIndex="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8E5;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="13"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="0,0,8,0" />
                            <TextBlock x:Name="DropHintText"
                                       Text="选择文件夹后，将视频拖到网格位置"
                                       FontSize="13"
                                       Foreground="{StaticResource InkBrush}" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="18,64,18,18">
                        <Grid x:Name="WorkspaceGrid"
                              AllowDrop="True"
                              DragOver="WorkspaceGrid_DragOver"
                              Drop="WorkspaceGrid_Drop" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="#FFFFFF"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1,0,0,0">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="248" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="待执行"
                                   Style="{StaticResource SectionTitle}" />
                        <TextBlock x:Name="PlanStatusText"
                                   Grid.Column="1"
                                   Text="无计划"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <ListBox x:Name="PreviewList"
                             Grid.Row="1"
                             Style="{StaticResource ListBoxBase}" />

                    <Grid Grid.Row="2" Margin="0,18,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="运行日志"
                                   Style="{StaticResource SectionTitle}" />
                        <TextBlock x:Name="LogStatusText"
                                   Grid.Column="1"
                                   Text="就绪"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <ListBox x:Name="LogList"
                             Grid.Row="3"
                             Style="{StaticResource ListBoxBase}" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Text="就绪"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="{StaticResource MutedBrush}" />
                <TextBlock Grid.Column="1"
                           Text="安全重命名：两阶段临时文件"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="{StaticResource MutedBrush}" />
            </Grid>
        </Border>
    </Grid>
</Window>
