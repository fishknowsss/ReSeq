<UserControl x:Class="ReSeq.Controls.LogListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <ListBox x:Name="LogList"
             ItemsSource="{Binding ItemsSource, ElementName=Root}"
             Style="{StaticResource InspectorListBox}">
        <ListBox.ItemTemplate>
            <DataTemplate>
                <Border x:Name="Row"
                        Background="{StaticResource SurfaceSubtleBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="9"
                        Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="IconCircle"
                                Width="18"
                                Height="18"
                                CornerRadius="9"
                                Background="#E8EDF4"
                                VerticalAlignment="Top">
                            <TextBlock Text="{Binding Icon}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding TimeText}"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="11"
                                   VerticalAlignment="Top" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Message}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Border>
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding LevelKey}" Value="Success">
                        <Setter TargetName="IconCircle" Property="Background" Value="{StaticResource SuccessSoftBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding LevelKey}" Value="Warning">
                        <Setter TargetName="Row" Property="Background" Value="{StaticResource WarningSoftBrush}" />
                        <Setter TargetName="IconCircle" Property="Background" Value="#FFE9A6" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding LevelKey}" Value="Error">
                        <Setter TargetName="Row" Property="Background" Value="{StaticResource ErrorSoftBrush}" />
                        <Setter TargetName="Row" Property="BorderBrush" Value="{StaticResource ErrorBorderBrush}" />
                        <Setter TargetName="IconCircle" Property="Background" Value="#FFD2CF" />
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>
