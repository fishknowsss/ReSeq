<UserControl x:Class="ReSeq.Controls.DropZoneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             AllowDrop="True"
             Tag="{Binding Target, ElementName=Root}">
    <Border x:Name="Zone"
            Background="Transparent"
            AllowDrop="True"
            Tag="{Binding Target, ElementName=Root}"
            DragEnter="Zone_DragEnter"
            DragLeave="Zone_DragLeave"
            Drop="Zone_Drop">
        <Border x:Name="Line"
                Width="{Binding LineWidth, ElementName=Root}"
                Height="{Binding LineHeight, ElementName=Root}"
                Background="Transparent"
                CornerRadius="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />
    </Border>
</UserControl>
