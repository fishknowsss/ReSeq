<UserControl x:Class="ReSeq.Controls.RenamePreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <ListBox ItemsSource="{Binding ItemsSource, ElementName=Root}"
             Style="{StaticResource InspectorListBox}">
        <ListBox.ItemTemplate>
            <DataTemplate>
                <Border Background="{StaticResource SurfaceSubtleBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="KindRail"
                                Background="#94A3B8"
                                CornerRadius="8,0,0,8" />
                        <Grid Grid.Column="1"
                              Margin="10,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding OldName}"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis" />
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,5,0,0">
                                    <TextBlock Text="→"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               FontSize="12"
                                               Margin="0,0,7,0" />
                                    <TextBlock Text="{Binding NewName}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Column="1"
                                    x:Name="KindTag"
                                    Background="#E8EDF4"
                                    CornerRadius="5"
                                    Padding="7,3"
                                    VerticalAlignment="Top">
                                <TextBlock Text="{Binding KindText}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding KindKey}" Value="Add">
                        <Setter TargetName="KindRail" Property="Background" Value="{StaticResource SuccessBrush}" />
                        <Setter TargetName="KindTag" Property="Background" Value="{StaticResource SuccessSoftBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding KindKey}" Value="Move">
                        <Setter TargetName="KindRail" Property="Background" Value="{StaticResource AccentBrush}" />
                        <Setter TargetName="KindTag" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding KindKey}" Value="Delete">
                        <Setter TargetName="KindRail" Property="Background" Value="{StaticResource ErrorBrush}" />
                        <Setter TargetName="KindTag" Property="Background" Value="{StaticResource ErrorSoftBrush}" />
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>
