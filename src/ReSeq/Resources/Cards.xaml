<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="CommandSurface" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style x:Key="RailSection" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource RailElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource RailBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style x:Key="PanelCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <Style x:Key="InspectorSection" TargetType="Border" BasedOn="{StaticResource PanelCard}">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <Style x:Key="FieldCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="9" />
        <Setter Property="Padding" Value="12,0" />
    </Style>

    <Style x:Key="DropHintBanner" TargetType="Border">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Background" Value="{StaticResource InkBrush}" />
        <Setter Property="BorderBrush" Value="#24314A" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="12,0" />
    </Style>

    <Style x:Key="MatrixHeaderCell" TargetType="Border">
        <Setter Property="Height" Value="34" />
        <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
    </Style>

    <Style x:Key="RowHeaderCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
    </Style>

    <Style x:Key="VideoCard" TargetType="Border">
        <Setter Property="Width" Value="168" />
        <Setter Property="Height" Value="136" />
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="#D8E2EF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Setter.Value>
        </Setter>
        <Style.Resources>
            <CubicEase x:Key="HoverEaseOut" EasingMode="EaseOut" />
        </Style.Resources>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                <Setter Property="Background" Value="{StaticResource SurfaceSubtleBrush}" />
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                             To="1.004"
                                             Duration="0:0:0.14"
                                             EasingFunction="{StaticResource HoverEaseOut}" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                             To="1.004"
                                             Duration="0:0:0.14"
                                             EasingFunction="{StaticResource HoverEaseOut}" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                             To="1"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource HoverEaseOut}" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                             To="1"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource HoverEaseOut}" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="EmptyCellCard" TargetType="Border">
        <Setter Property="Width" Value="168" />
        <Setter Property="Height" Value="136" />
        <Setter Property="Background" Value="#F5F8FC" />
        <Setter Property="BorderBrush" Value="#E2E9F2" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Opacity" Value="0.72" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                <Setter Property="Background" Value="#EEF4FF" />
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="0.96"
                                             Duration="0:0:0.12" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                             To="1.003"
                                             Duration="0:0:0.14"
                                             EasingFunction="{StaticResource HoverEaseOut}" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                             To="1.003"
                                             Duration="0:0:0.14"
                                             EasingFunction="{StaticResource HoverEaseOut}" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="0.72"
                                             Duration="0:0:0.18" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                             To="1"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource HoverEaseOut}" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                             To="1"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource HoverEaseOut}" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="CompactMetricCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="10,8" />
    </Style>

    <Style x:Key="EmptyPanelCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="MinHeight" Value="118" />
    </Style>
</ResourceDictionary>
