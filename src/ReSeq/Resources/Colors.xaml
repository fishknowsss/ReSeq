<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="ColorShell">#F3F6FA</Color>
    <Color x:Key="ColorWorkspace">#F7F9FC</Color>
    <Color x:Key="ColorSurface">#FFFFFF</Color>
    <Color x:Key="ColorSurfaceMuted">#F1F5F9</Color>
    <Color x:Key="ColorSurfaceSubtle">#FAFBFD</Color>

    <Color x:Key="ColorRail">#121A26</Color>
    <Color x:Key="ColorRailElevated">#192435</Color>
    <Color x:Key="ColorRailBorder">#263447</Color>
    <Color x:Key="ColorRailText">#EEF4FF</Color>
    <Color x:Key="ColorRailMuted">#91A0B7</Color>

    <Color x:Key="ColorBorder">#D5DEE9</Color>
    <Color x:Key="ColorBorderSoft">#E5EBF2</Color>
    <Color x:Key="ColorBorderStrong">#AAB7C8</Color>
    <Color x:Key="ColorTextPrimary">#111827</Color>
    <Color x:Key="ColorTextSecondary">#4B5870</Color>
    <Color x:Key="ColorTextTertiary">#7B8798</Color>
    <Color x:Key="ColorAccent">#2563D8</Color>
    <Color x:Key="ColorAccentDark">#174EA6</Color>
    <Color x:Key="ColorAccentSoft">#E7EEFD</Color>
    <Color x:Key="ColorSuccess">#16794C</Color>
    <Color x:Key="ColorSuccessSoft">#EAF6EF</Color>
    <Color x:Key="ColorWarning">#A16207</Color>
    <Color x:Key="ColorWarningSoft">#FFF7DF</Color>
    <Color x:Key="ColorWarningBorder">#E9C969</Color>
    <Color x:Key="ColorError">#B42318</Color>
    <Color x:Key="ColorErrorSoft">#FFF1F0</Color>
    <Color x:Key="ColorErrorBorder">#F0B6AF</Color>
    <Color x:Key="ColorInk">#0F172A</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource ColorShell}" />
    <SolidColorBrush x:Key="WorkspaceBrush" Color="{StaticResource ColorWorkspace}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{StaticResource ColorSurfaceMuted}" />
    <SolidColorBrush x:Key="SurfaceSubtleBrush" Color="{StaticResource ColorSurfaceSubtle}" />
    <SolidColorBrush x:Key="RailBrush" Color="{StaticResource ColorRail}" />
    <SolidColorBrush x:Key="RailElevatedBrush" Color="{StaticResource ColorRailElevated}" />
    <SolidColorBrush x:Key="RailBorderBrush" Color="{StaticResource ColorRailBorder}" />
    <SolidColorBrush x:Key="RailTextBrush" Color="{StaticResource ColorRailText}" />
    <SolidColorBrush x:Key="RailMutedBrush" Color="{StaticResource ColorRailMuted}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource ColorBorder}" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="{StaticResource ColorBorderSoft}" />
    <SolidColorBrush x:Key="BorderBrushStrong" Color="{StaticResource ColorBorderStrong}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource ColorTextTertiary}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource ColorAccent}" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource ColorAccentDark}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource ColorAccentSoft}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource ColorSuccess}" />
    <SolidColorBrush x:Key="SuccessSoftBrush" Color="{StaticResource ColorSuccessSoft}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource ColorWarning}" />
    <SolidColorBrush x:Key="WarningSoftBrush" Color="{StaticResource ColorWarningSoft}" />
    <SolidColorBrush x:Key="WarningBorderBrush" Color="{StaticResource ColorWarningBorder}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ColorError}" />
    <SolidColorBrush x:Key="ErrorSoftBrush" Color="{StaticResource ColorErrorSoft}" />
    <SolidColorBrush x:Key="ErrorBorderBrush" Color="{StaticResource ColorErrorBorder}" />
    <SolidColorBrush x:Key="InkBrush" Color="{StaticResource ColorInk}" />
</ResourceDictionary>
