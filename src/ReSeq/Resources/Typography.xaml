<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <FontFamily x:Key="AppFont">Segoe UI, Microsoft YaHei UI</FontFamily>
    <FontFamily x:Key="AppFontFamily">Segoe UI, Microsoft YaHei UI</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas</FontFamily>

    <Style x:Key="AppText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    </Style>

    <Style x:Key="TitleText" TargetType="TextBlock" BasedOn="{StaticResource AppText}">
        <Setter Property="FontSize" Value="21" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="RailTitleText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="Foreground" Value="{StaticResource RailTextBrush}" />
        <Setter Property="FontSize" Value="21" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="RailMutedText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="Foreground" Value="{StaticResource RailMutedBrush}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="SectionTitleText" TargetType="TextBlock" BasedOn="{StaticResource AppText}">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="BodyText" TargetType="TextBlock" BasedOn="{StaticResource AppText}">
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style x:Key="BodyStrongText" TargetType="TextBlock" BasedOn="{StaticResource BodyText}">
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="MutedText" TargetType="TextBlock" BasedOn="{StaticResource AppText}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="SubtleLabelText" TargetType="TextBlock" BasedOn="{StaticResource AppText}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}" />
    </Style>

    <Style x:Key="MetricText" TargetType="TextBlock" BasedOn="{StaticResource AppText}">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="MatrixHeaderText" TargetType="TextBlock" BasedOn="{StaticResource AppText}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="MatrixIndexText" TargetType="TextBlock" BasedOn="{StaticResource AppText}">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="StatusText" TargetType="TextBlock" BasedOn="{StaticResource AppText}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="CaptionText" TargetType="TextBlock" BasedOn="{StaticResource AppText}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="MonoBadgeText" TargetType="TextBlock" BasedOn="{StaticResource AppText}">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
</ResourceDictionary>
